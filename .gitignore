# cfblocklist .gitignore

# Runtime config for /opt/blocklist scripts — contains DB credentials
blocklist.conf


# Your live blocklist config — copy blocklist.conf.example to /etc/blocklist/blocklist.conf
# Never committed; the .example file is the committed template.
/etc/blocklist/blocklist.conf

# Your live settings file — copy settings.example.cfm to settings.cfm and fill it in.
# Never committed; settings.example.cfm is the committed template.
config/settings.cfm

# The pepper flat file (if you use Tier 3 flat-file method).
# The actual filename/path is whatever you set in application.pepperFile —
# add it here if it falls inside the project directory for any reason.
# Example:
# secrets/pepper.txt

# Lucee / ColdFusion runtime artifacts
*.cfswc
*.cfswc.settings
*.lock
WEB-INF/

# OS artifacts
.DS_Store
Thumbs.db

# Editor directories
.idea/
.vscode/
*.swp
