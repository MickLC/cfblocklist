# cfblocklist .gitignore

# The pepper flat file (if you use Tier 3 flat-file method).
# The actual filename/path is whatever you set in application.pepperFile —
# add it here if it falls inside the project directory for any reason.
# Example:
# secrets/pepper.txt

# Lucee / ColdFusion runtime artifacts
*.cfswc
*.cfswc.settings
*.lock
WEB-INF/

# OS artifacts
.DS_Store
Thumbs.db

# Editor directories
.idea/
.vscode/
*.swp
